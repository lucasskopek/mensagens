generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  whatsapp  String?
  isDev     Boolean  @default(false)
  credits   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contacts    Contact[]
  schedules   Schedule[]
  config      UserConfig?
  history     MessageHistory[]
}

model UserConfig {
  id              String   @id @default(cuid())
  userId          String   @unique
  setupCompleted  Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Contact {
  id        String   @id @default(cuid())
  userId    String
  name      String
  phone     String
  nicknames String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules Schedule[]
}

model Schedule {
  id            String   @id @default(cuid())
  userId        String
  contactId     String
  messageStyles String   // JSON array of styles: romantic,spicy,playful,serious
  timesPerDay   Int      @default(1)
  sendTimes     String   // JSON array of times: ["08:00","14:00","20:00"]
  recurring     Boolean  @default(true)  // true = 365 dias/ano, false = datas especificas
  selectedDates String   @default("[]") // JSON array of dates: ["2025-01-15","2025-02-14"]
  executionLog  String   @default("[]") // JSON array of executed slots: ["2025-01-15|08:00", ...]
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model MessageHistory {
  id          String   @id @default(cuid())
  userId      String
  contactId   String
  contactName String
  phoneNumber String
  message     String
  style       String
  status      String   @default("pending") // pending, sent, delivered, failed
  sentAt      DateTime @default(now())
  deliveredAt DateTime?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}